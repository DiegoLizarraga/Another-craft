# ── Minecraft ─────────────────────────────────────────────────────────────────
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=mina
MC_VERSION=1.21.1

# Jugador "dueño" por defecto (a quién sigue/da items si el LLM no lo dice). Opcional.
# MC_OWNER=TuNombreDeUsuario

# ── Comportamiento de mina ────────────────────────────────────────────────────
# Cada cuánto (ms) toma una decisión autónoma con el LLM cuando no hay nada urgente.
THINK_INTERVAL_MS=20000
# Si se defiende sola al ser golpeada por un mob ("true" por defecto).
MINA_DEFEND=true

# ── LLM Provider: "ollama" | "openrouter" ────────────────────────────────────
LLM_PROVIDER=ollama

# Tiempo máximo (ms) de espera al LLM antes de abortar (evita que mina se cuelgue
# "pensando" si el modelo no responde). Por defecto 15000.
LLM_TIMEOUT_MS=15000

# Ollama (local, gratis)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=dolphin-phi

# OpenRouter (modelos gratis online, mejor calidad de JSON que dolphin-phi)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
# Otros modelos gratis: deepseek/deepseek-r1:free | google/gemma-3-12b:free

# ── Viewer (navegador) ────────────────────────────────────────────────────────
VIEWER_ENABLED=false
VIEWER_PORT=3007
